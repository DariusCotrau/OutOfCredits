# =============================================================================
# ChiriiSmart — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Variables marked [REQUIRED] must be set before running the app.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (MySQL)                                              [REQUIRED]
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=chiriismart
DB_PASSWORD=chiriismart
DB_DATABASE=chiriismart
# WARNING: synchronize=true auto-syncs schema and can DROP columns/data.
# Use migrations in production. Only set to true for initial local dev.
DB_SYNCHRONIZE=false

# -----------------------------------------------------------------------------
# JWT Authentication                                            [REQUIRED]
# -----------------------------------------------------------------------------
# Generate random 64-char strings: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRATION=7d

# -----------------------------------------------------------------------------
# Google OAuth 2.0                                              [REQUIRED for Google login]
# -----------------------------------------------------------------------------
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# -----------------------------------------------------------------------------
# Google Maps API                                               [REQUIRED for maps/recommendations]
# -----------------------------------------------------------------------------
# Enable Geocoding API + Directions API + Places API in Google Cloud Console
GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Scraper Configuration                                         [OPTIONAL]
# -----------------------------------------------------------------------------
SCRAPER_ENABLED=true
SCRAPER_CRON=0 */6 * * *
SCRAPER_DELAY_MIN=2000
SCRAPER_DELAY_MAX=5000

# -----------------------------------------------------------------------------
# Application                                                   [REQUIRED]
# -----------------------------------------------------------------------------
PORT=3000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
